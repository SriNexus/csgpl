# =====================================================================
# CSGPL Frontend — Environment Variables
# Copy this file to `.env.local` for local development, or configure
# these as build-time environment variables in your hosting platform.
# =====================================================================

# Public site URL (no trailing slash). Used for canonical URLs, OG tags,
# sitemap entries, and absolute link generation.
VITE_SITE_URL=https://csgpl.in

# Set to "false" to force the app into local-fallback mode and skip
# Firebase calls. Useful for offline preview / Storybook environments.
VITE_FIREBASE_ENABLED=true
